# Copy to .env.local and fill in. NEVER commit .env.local (it is gitignored).
# NEXT_PUBLIC_* values are exposed to the browser; everything else is server-only.

# --- Chain selection ---------------------------------------------------------
NEXT_PUBLIC_CHAIN=robinhood            # robinhood (EVM) | solana

# --- Auth / embedded wallet --------------------------------------------------
NEXT_PUBLIC_PRIVY_APP_ID=

# --- EVM (Robinhood Chain) ---------------------------------------------------
# Mainnet (chainId 4663) reference values, verified on-chain 2026-07-22:
#   EVM_MAINNET_RPC_URL=https://robinhood-mainnet.g.alchemy.com/v2/<key>  (server-only)
#   EVM_LOGS_RPC_URL=https://robinhoodchain.blockscout.com/api/eth-rpc    (wide getLogs)
#   NEXT_PUBLIC_EVM_NETWORK=mainnet
#   NEXT_PUBLIC_EVM_LOG_RANGE=900
#   NEXT_PUBLIC_ANNOUNCER_ADDR=0x55649E01B5Df198D18D95b5cc5051630cfD45564  (canonical ERC-5564)
#   NEXT_PUBLIC_USDG_ADDR=0x5fc5360D0400a0Fd4f2af552ADD042D716F1d168       (Paxos USDG, baked-in default)
#   (USDC/USDT: no canonical RH-mainnet deployment — leave unset)
EVM_RPC_URL=                           # server-side RPC (proxied, IP hidden)
EVM_MAINNET_RPC_URL=
EVM_LOGS_RPC_URL=                      # optional: dedicated eth_getLogs endpoint
NEXT_PUBLIC_EVM_RPC=                   # optional public fallback
NEXT_PUBLIC_EVM_NETWORK=
NEXT_PUBLIC_EVM_LOG_RANGE=1000
NEXT_PUBLIC_ANNOUNCER_ADDR=            # ERC-5564 announcer
NEXT_PUBLIC_USDG_ADDR=
NEXT_PUBLIC_USDC_ADDR=
NEXT_PUBLIC_USDT_ADDR=
NEXT_PUBLIC_EVM_GASLESS=false
NEXT_PUBLIC_PIMLICO_KEY=               # only if gasless is enabled

# --- Solana ------------------------------------------------------------------
NEXT_PUBLIC_SOLANA_RPC=
SOLANA_RPC=                            # server-side
UMBRA_TEST_SECRET=                     # THROWAWAY devnet key — dev routes only

# --- ENS / BlackVault Names --------------------------------------------------
NEXT_PUBLIC_NAMES_PARENT=blackvaultwallet.eth
ENS_RPC_URL=                           # server-side ENS RPC (proxied)
NEXT_PUBLIC_ENS_RPC=                   # optional public fallback
NAMES_GATEWAY_KEY=                     # THROWAWAY testnet key that signs CCIP-Read answers
NAMESTONE_API_KEY=                     # legacy, only for the old ens/claim route
# Paid subname claims: price in USDG (unset/0 = free) + the wallet that
# receives payment. The claim route verifies the USDG transfer on-chain.
NAMES_PRICE_USDG=
NAMES_REVENUE_ADDR=

# --- Vault Keeper assistant --------------------------------------------------
ANTHROPIC_API_KEY=
